---
/**
 * Home page — /
 *
 * Renders HomeApp as a React client island.
 * Passes only article METADATA (no content) to the browser.
 * deepContents.ts (951 KB) is used only at build time and never shipped.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import HomeApp from '../components/HomeApp'
import { libraryMeta } from '../data/library'

const siteUrl = 'https://french.milovicake.ru'

// JSON-LD: Organization — sameAs links help Google build the Knowledge Graph entity
const jsonLdOrg = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patisserie Russe / Milovi School',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/images/logo.svg`,
  },
  description:
    'Библиотека материалов о французской кондитерской школе. Гроле, Эрме, Мишалак, Метайе, Куврер — техники, разборы, рецепты.',
  inLanguage: 'ru',
  sameAs: ['https://milovicake.ru'],
}

// JSON-LD: WebSite with SearchAction for Google Sitelinks Searchbox
const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Patisserie Russe',
  url: siteUrl,
  inLanguage: 'ru',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout
  title="Patisserie Russe — Французская кондитерская школа"
  description="Библиотека материалов о французской кондитерской школе. Гроле, Эрме, Мишалак, Метайе, Куврер — техники, разборы, рецепты."
  canonicalUrl="https://french.milovicake.ru/"
  ogType="website"
  image="/images/og-preview.webp"
  ogImageWidth={1200}
  ogImageHeight={630}
>
  <!-- JSON-LD: Organization -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} slot="head" />
  <!-- JSON-LD: WebSite + SearchAction -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} slot="head" />

  <!--
    client:load — гидратируется сразу при загрузке страницы.
    articles содержит только метаданные: id, title, excerpt, category, author,
    readTime, image, tags. Контент статей НЕ передаётся на главную страницу.
  -->
  <HomeApp articles={libraryMeta} client:load />
</BaseLayout>
