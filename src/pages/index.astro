---
import BaseLayout from '../layouts/BaseLayout.astro'
import HomeApp from '../components/HomeApp'
import { libraryClientMeta } from '../data/library'

const siteUrl = 'https://french.milovicake.ru'

const jsonLdOrg = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Patisserie Russe / Milovi School',
  url: siteUrl,
  logo: {
    '@type': 'ImageObject',
    url: `${siteUrl}/images/logo.png`,
  },
  description:
    'Библиотека материалов о французской кондитерской школе. Гроле, Эрме, Мишалак, Метайе, Куврер — техники, разборы, рецепты.',
  inLanguage: 'ru',
  sameAs: ['https://milovicake.ru'],
}

const jsonLdWebSite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Patisserie Russe',
  url: siteUrl,
  inLanguage: 'ru',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteUrl}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout
  title="Patisserie Russe — Французская кондитерская школа"
  description="Библиотека материалов о французской кондитерской школе. Гроле, Эрме, Мишалак, Метайе, Куврер — техники, разборы, рецепты."
  canonicalUrl="https://french.milovicake.ru/"
  ogType="website"
  image="/images/og-preview.webp"
  ogImageWidth={1200}
  ogImageHeight={630}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdOrg)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} slot="head" />

  <HomeApp articles={libraryClientMeta} client:load />
</BaseLayout>
