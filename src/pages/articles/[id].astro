---
/**
 * Article page — /articles/<id>/
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticlePageShell from '../../components/ArticlePageShell'
import { libraryArticles, libraryMeta } from '../../data/library'
import { categories } from '../../data/categories'
import type { Article } from '../../data/articles'

export function getStaticPaths() {
  return libraryArticles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }))
}

const { article } = Astro.props as { article: Article }

const siteUrl = 'https://french.milovicake.ru'
const canonicalUrl = `${siteUrl}/articles/${article.id}/`
const pageTitle = `${article.title} — Patisserie Russe`

const categoryName = categories.find((c) => c.id === article.category)?.name ?? article.category

// ── OG image ────────────────────────────────────────────────────────────────
function buildOgImage(input: string | undefined): { url: string; width?: number; height?: number } {
  if (!input) {
    return { url: `${siteUrl}/images/og-preview.webp`, width: 1200, height: 630 }
  }
  if (input.includes('unsplash.com')) {
    const base = input.split('?')[0]
    return {
      url: `${base}?w=1200&h=630&fit=crop&crop=center&auto=format`,
      width: 1200,
      height: 630,
    }
  }
  // Local WEBP article images — use standard OG dimensions so FB/VK/TG can render the preview
  const absolute = input.startsWith('http') ? input : `${siteUrl}${input}`
  return { url: absolute, width: 1200, height: 800 }
}

const ogImg = buildOgImage(article.image)

// ── Structured data ──────────────────────────────────────────────────────────
const wordCount = Math.round((article.content?.length ?? 0) / 6)

// `author` field in articles.ts often holds a *source list* like
// "AFP, Michelin Guide, Pastry Workshop". Splitting on comma turns that into
// a clean Person[] array — Google then displays the first as primary author
// and treats the rest as additional authors. If it is a single name (no comma),
// the array contains a single Person entry, which is also valid schema.
const authorList = (article.author ?? '')
  .split(/\s*[,;/]\s*/)
  .map((name) => name.trim())
  .filter(Boolean)

// In article data, `author` is an editorial source/source-list. The real author of
// this educational adaptation is the project library; original sources are exposed
// through `citation`/visible source links to avoid source ≠ author schema pollution.
const jsonLdAuthor = {
  '@type': 'Organization',
  name: 'Milovi School / Patisserie Russe',
  url: siteUrl,
}

const jsonLdImage = {
  '@type': 'ImageObject',
  url: ogImg.url,
  contentUrl: ogImg.url,
  width: article.imageWidth ?? ogImg.width ?? 1280,
  height: article.imageHeight ?? ogImg.height ?? 800,
  caption: article.imageCaption ?? article.title,
  name: article.imageTitle ?? article.title,
  creditText: article.imageCredit ?? 'Patisserie Russe / Milovi School',
  representativeOfPage: true,
}

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.excerpt,
  image: jsonLdImage,
  inLanguage: 'ru',
  wordCount,
  author: jsonLdAuthor,
  publisher: {
    '@type': 'Organization',
    name: 'Patisserie Russe / Milovi School',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.png`,
    },
  },
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  keywords: article.tags?.join(', '),
  ...(article.sourceUrl ? { citation: article.sourceUrl } : {}),
  ...(article.date
    ? {
        datePublished: article.date,
        dateModified: article.updatedAt ?? article.date,
      }
    : {}),
}

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Patisserie Russe',
      item: `${siteUrl}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: categoryName,
      item: `${siteUrl}/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.title,
      item: canonicalUrl,
    },
  ],
}

// ── Recipe JSON-LD ───────────────────────────────────────────────────────────
// CRITICAL: emit Recipe schema ONLY if recipeData is fully populated AND we
// can extract real, numbered cooking steps from the article content. Stub data
// like "Ингредиенты указаны в статье" or one-line instructions is treated by
// Google as structured-data spam (manual action risk in Search Console).
function extractRecipeSteps(content: string | undefined): { '@type': 'HowToStep'; text: string }[] {
  if (!content) return []
  // Numbered "1. step" or "1) step" lines, must contain at least 12 characters
  // of content (filters out year stamps like "1985." and noise).
  const stepRegex = /^\s*\d{1,2}[.)]\s+(.{12,})$/gm
  const steps: { '@type': 'HowToStep'; text: string }[] = []
  let match: RegExpExecArray | null
  while ((match = stepRegex.exec(content)) !== null) {
    steps.push({ '@type': 'HowToStep', text: match[1].trim() })
  }
  return steps
}

let jsonLdRecipe: Record<string, unknown> | null = null
const recipeData = article.recipeData
const realIngredients =
  recipeData?.ingredients?.filter((i) => i && !/указаны в статье/i.test(i)) ?? []
const realSteps = extractRecipeSteps(article.content)

if (
  recipeData &&
  recipeData.prepTime &&
  recipeData.cookTime &&
  recipeData.yield &&
  realIngredients.length >= 2 &&
  realSteps.length >= 2
) {
  jsonLdRecipe = {
    '@context': 'https://schema.org/',
    '@type': 'Recipe',
    name: article.title,
    image: jsonLdImage,
    author: jsonLdAuthor,
    ...(article.date ? { datePublished: article.date } : {}),
    description: article.excerpt,
    prepTime: recipeData.prepTime,
    cookTime: recipeData.cookTime,
    recipeYield: recipeData.yield,
    recipeIngredient: realIngredients,
    recipeInstructions: realSteps,
    ...(recipeData.calories
      ? {
          nutrition: {
            '@type': 'NutritionInformation',
            calories: recipeData.calories,
          },
        }
      : {}),
  }
}

// ── FAQ JSON-LD — only when the article actually has FAQ entries ─────────────
let jsonLdFAQ: Record<string, unknown> | null = null
if (article.faq && article.faq.length > 0) {
  jsonLdFAQ = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: article.faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  }
}
---

<BaseLayout
  title={pageTitle}
  description={article.excerpt}
  image={ogImg.url}
  ogImageWidth={ogImg.width}
  ogImageHeight={ogImg.height}
  canonicalUrl={canonicalUrl}
  ogType="article"
  articlePublishedTime={article.date}
  articleModifiedTime={article.updatedAt ?? article.date}
  articleAuthor="Milovi School / Patisserie Russe"
  articleSection={categoryName}
  articleTags={article.tags}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdArticle)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} slot="head" />
  {jsonLdRecipe && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdRecipe)} slot="head" />}
  {jsonLdFAQ && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} slot="head" />}

  <ArticlePageShell article={article} allMeta={libraryMeta} client:load />
</BaseLayout>
