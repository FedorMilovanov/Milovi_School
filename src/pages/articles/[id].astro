---
/**
 * Article page вҖ” /articles/<id>/
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticlePageShell from '../../components/ArticlePageShell'
import { libraryArticles, libraryClientMeta } from '../../data/library'
import { categories } from '../../data/categories'
import type { Article } from '../../data/types'

export function getStaticPaths() {
  return libraryArticles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }))
}

const { article } = Astro.props as { article: Article }

const siteUrl = 'https://french.milovicake.ru'
const canonicalUrl = `${siteUrl}/articles/${article.id}/`
const pageTitle = `${article.title} вҖ” Patisserie Russe`

const categoryName = categories.find((c) => c.id === article.category)?.name ?? article.category

// в”Җв”Җ OG image в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
function buildOgImage(input: string | undefined, width?: number, height?: number): { url: string; width?: number; height?: number } {
  if (!input) {
    return { url: `${siteUrl}/images/og-preview.webp`, width: 1200, height: 630 }
  }
  if (input.includes('unsplash.com')) {
    const base = input.split('?')[0]
    return {
      url: `${base}?w=1200&h=630&fit=crop&crop=center&auto=format`,
      width: 1200,
      height: 630,
    }
  }
  // Local article images вҖ” keep OG/JSON-LD dimensions in sync with the real file.
  const absolute = input.startsWith('http') ? input : `${siteUrl}${input}`
  return { url: absolute, width: width ?? 1280, height: height ?? 800 }
}

const ogImg = buildOgImage(article.image, article.imageWidth, article.imageHeight)

// в”Җв”Җ Structured data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
const wordCount = (article.content ?? '').replace(/\s+/g, ' ').split(' ').filter(Boolean).length

// In article data, `author` is an editorial source/source-list. The real author of
// this educational adaptation is the project library; original sources are exposed
// through `citation`/visible source links to avoid source вү  author schema pollution.
const jsonLdAuthor = {
  '@type': 'Organization',
  name: 'Milovi School / Patisserie Russe',
  url: siteUrl,
}

const jsonLdImage = {
  '@type': 'ImageObject',
  url: ogImg.url,
  contentUrl: ogImg.url,
  width: article.imageWidth ?? ogImg.width ?? 1280,
  height: article.imageHeight ?? ogImg.height ?? 800,
  caption: article.imageCaption ?? article.title,
  name: article.imageTitle ?? article.title,
  creditText: article.imageCredit ?? 'Patisserie Russe / Milovi School',
  representativeOfPage: true,
}

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.excerpt,
  image: jsonLdImage,
  inLanguage: 'ru',
  wordCount,
  author: jsonLdAuthor,
  publisher: {
    '@type': 'Organization',
    name: 'Patisserie Russe / Milovi School',
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/images/logo.svg`,
    },
  },
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  keywords: article.tags?.join(', '),
  ...(article.sourceUrl ? { citation: article.sourceUrl } : {}),
  ...(article.date
    ? {
        datePublished: article.date,
        dateModified: article.updatedAt ?? article.date,
      }
    : {}),
}

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Patisserie Russe',
      item: `${siteUrl}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: categoryName,
      item: `${siteUrl}/#archive`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.title,
      item: canonicalUrl,
    },
  ],
}

// в”Җв”Җ Recipe JSON-LD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// CRITICAL: emit Recipe schema ONLY if recipeData is fully populated AND we
// can extract real, numbered cooking steps from the article content. Stub data
// like "РҳРҪРіСҖРөРҙРёРөРҪСӮСӢ СғРәР°Р·Р°РҪСӢ РІ СҒСӮР°СӮСҢРө" or one-line instructions is treated by
// Google as structured-data spam (manual action risk in Search Console).
function extractRecipeSteps(content: string | undefined): { '@type': 'HowToStep'; text: string }[] {
  if (!content) return []
  // Numbered "1. step" or "1) step" lines, must contain at least 12 characters
  // of content (filters out year stamps like "1985." and noise).
  const stepRegex = /^\s*\d{1,2}[.)]\s+(.{12,})$/gm
  const cookingVerb = /(СҒРјРөСҲ|РІР·Рұ|РҙРҫРұР°РІ|РІРІРөРҙ|СҖР°СҒСӮРҫРҝ|РҙРҫРІРөРҙ|РІСӢРҝРөРә|РҫС…Р»Р°Рҙ|Р·Р°РјРҫСҖРҫР·|СҖР°СҒРәР°СӮ|РҪР°СҖРөР¶|СҒРҫРұРөСҖ|РҝРөСҖРөР»РҫР¶|РҝСҖРҫСҶРөРҙ|РҝСҖРҫРұРөР№|РҝСҖРҫРұРёСӮСҢ|РҪР°РіСҖ|РІР°СҖ|Р·Р°РІР°СҖ|РІР»РөР№|РІР»РёСӮСҢ|РІСӢР»РҫР¶|РҝРөСҖРөРјРөСҲ|РәР°СҖР°РјРөР»РёР·|СӮРөРјРҝРөСҖРёСҖ|РҫСӮСҒР°Рҙ|РҪР°РәСҖРҫР№|РҫСҒСӮР°РІСҢ|СҒРҪРёРјРё|СҒРҪСҸСӮСҢ)/i
  const steps: { '@type': 'HowToStep'; text: string }[] = []
  let match: RegExpExecArray | null
  while ((match = stepRegex.exec(content)) !== null) {
    const text = match[1].trim()
    if (cookingVerb.test(text)) steps.push({ '@type': 'HowToStep', text })
  }
  return steps
}

let jsonLdRecipe: Record<string, unknown> | null = null
const recipeData = article.recipeData
const realIngredients =
  recipeData?.ingredients?.filter((i) => i && !/СғРәР°Р·Р°РҪСӢ РІ СҒСӮР°СӮСҢРө/i.test(i)) ?? []
const realSteps = extractRecipeSteps(article.content)

if (
  recipeData &&
  recipeData.prepTime &&
  recipeData.cookTime &&
  recipeData.yield &&
  realIngredients.length >= 2 &&
  realSteps.length >= 2
) {
  jsonLdRecipe = {
    '@context': 'https://schema.org/',
    '@type': 'Recipe',
    name: article.title,
    image: jsonLdImage,
    author: jsonLdAuthor,
    ...(article.date ? { datePublished: article.date } : {}),
    description: article.excerpt,
    prepTime: recipeData.prepTime,
    cookTime: recipeData.cookTime,
    recipeYield: recipeData.yield,
    recipeIngredient: realIngredients,
    recipeInstructions: realSteps,
    ...(recipeData.calories
      ? {
          nutrition: {
            '@type': 'NutritionInformation',
            calories: recipeData.calories,
          },
        }
      : {}),
  }
}

// в”Җв”Җ FAQ JSON-LD вҖ” only when the article actually has FAQ entries в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
let jsonLdFAQ: Record<string, unknown> | null = null
if (article.faq && article.faq.length > 0) {
  jsonLdFAQ = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: article.faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  }
}
const safeJsonLd = (value: unknown) => JSON.stringify(value).replace(/</g, '\u003c')
---

<BaseLayout
  title={pageTitle}
  description={article.excerpt}
  image={ogImg.url}
  ogImageWidth={ogImg.width}
  ogImageHeight={ogImg.height}
  canonicalUrl={canonicalUrl}
  ogType="article"
  articlePublishedTime={article.date}
  articleModifiedTime={article.updatedAt ?? article.date}
  articleAuthor="Milovi School / Patisserie Russe"
  articleSection={categoryName}
  articleTags={article.tags}
>
  <script is:inline type="application/ld+json" set:html={safeJsonLd(jsonLdArticle)} slot="head" />
  <script is:inline type="application/ld+json" set:html={safeJsonLd(jsonLdBreadcrumb)} slot="head" />
  {jsonLdRecipe && <script is:inline type="application/ld+json" set:html={safeJsonLd(jsonLdRecipe)} slot="head" />}
  {jsonLdFAQ && <script is:inline type="application/ld+json" set:html={safeJsonLd(jsonLdFAQ)} slot="head" />}

  <ArticlePageShell article={article} allMeta={libraryClientMeta} client:load />
</BaseLayout>
