---
import BaseLayout from '../layouts/BaseLayout.astro'
import GalleryApp from '../components/gallery/GalleryApp'
import { libraryClientMeta } from '../data/library'

const safeJsonLd = (value: unknown) => JSON.stringify(value).replace(/</g, '\u003c')
---

<BaseLayout
  title="Материалы — Patisserie Russe"
  description="Полная библиотека материалов о французской кондитерской школе. Все статьи и рецепты."
  canonicalUrl="https://french.milovicake.ru/materials/"
>
  <GalleryApp articles={libraryClientMeta} client:load />
</BaseLayout>
