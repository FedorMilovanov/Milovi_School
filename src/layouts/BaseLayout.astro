---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  image?: string
  canonicalUrl?: string
  /** 'website' for home, 'article' for article pages */
  ogType?: 'website' | 'article'
  /** Explicit OG image dimensions — only pass when the exact size is known */
  ogImageWidth?: number
  ogImageHeight?: number
  /** Article-specific OG properties */
  articlePublishedTime?: string
  articleModifiedTime?: string
  articleAuthor?: string
  articleSection?: string
  articleTags?: string[]
}

const {
  title = 'Patisserie Russe — Французская кондитерская школа',
  description = 'Библиотека материалов о французской кондитерской школе. Гроле, Эрме, Мишалак, Метайе, Куврер — техники, разборы, рецепты.',
  image = '/images/premium-hero.jpg',
  canonicalUrl = 'https://french.milovicake.ru/',
  ogType = 'website',
  ogImageWidth,
  ogImageHeight,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor,
  articleSection,
  articleTags,
} = Astro.props

const siteUrl = 'https://french.milovicake.ru'

// Normalise image: plain string, Vite-resolved path string, or Astro ImageMetadata
const rawImage: string =
  typeof image === 'string'
    ? image
    : typeof image === 'object' && image !== null && 'src' in image
      ? (image as { src: string }).src
      : '/images/premium-hero.jpg'

const ogImage = rawImage.startsWith('http') ? rawImage : `${siteUrl}${rawImage}`

// Trim description to 160 chars for Google snippet (no mid-word truncation)
const lastSpace = description.lastIndexOf(' ', 157)
const metaDescription =
  description.length > 160
    ? description.slice(0, lastSpace > 0 ? lastSpace : 157) + '…'
    : description
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    {articleAuthor && <meta name="author" content={articleAuthor} />}

    <!-- Language targeting (hreflang) -->
    <link rel="alternate" hreflang="ru" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    {ogImageWidth && <meta property="og:image:width" content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Patisserie Russe" />
    <meta property="og:locale" content="ru_RU" />
    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && (articleModifiedTime ?? articlePublishedTime) && (
      <meta
        property="article:modified_time"
        content={articleModifiedTime ?? articlePublishedTime}
      />
    )}
    {ogType === 'article' && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === 'article' && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === 'article' && articleTags?.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <!--
      Theme colour — single dynamic <meta>. Static media-query variants
      were ignored by Chrome on Android when the user manually toggled
      the theme via JS. We expose ONE meta and update it from the
      pre-paint inline script below + on every theme change in React.
    -->
    <meta id="theme-color-meta" name="theme-color" content="#10100f" />

    <!-- Favicon — relative paths only (absolute URLs break on localhost) -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- PWA manifest -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Google Search Console verification slot -->
    <slot name="google-verification" />

    <!--
      Font loading strategy:
      1. preconnect — open the TLS handshake early
      2. preload the critical CSS file so the parser doesn't wait for the
         <link rel="stylesheet"> further down to discover it
      3. actual stylesheet still loads non-blocking via the regular link
    -->
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    />

    <!--
      Theme — apply BEFORE first paint to prevent flash of unstyled content (FOUC).
      Sets <html class="dark"> and updates the single theme-color <meta> in one
      pass so Android Chrome shows the right system bar even on first paint.

      ⚠ CSP note: if you ever add a Content-Security-Policy header with
        `script-src 'self'`, this inline script will be blocked. Fix by either:
          a) whitelisting it with its SHA-256 hash:
             `script-src 'self' 'sha256-<hash>'`
          b) replacing it with a `<script src="/theme-init.js">` from /public
    -->
    <script is:inline>
      (function () {
        var THEME_LIGHT = '#f5efe5'
        var THEME_DARK = '#10100f'
        var theme = 'dark'
        try {
          var s = localStorage.getItem('theme')
          if (s === 'light') theme = 'light'
        } catch (_) { /* private browsing — fall back to dark */ }
        var root = document.documentElement
        if (theme === 'dark') {
          root.classList.add('dark')
          root.style.colorScheme = 'dark'
        } else {
          root.style.colorScheme = 'light'
        }
        var meta = document.getElementById('theme-color-meta')
        if (meta) meta.setAttribute('content', theme === 'dark' ? THEME_DARK : THEME_LIGHT)
      })()
    </script>

    <!-- Page-specific head content (JSON-LD, extra meta, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!--
      Skip-to-content link — keyboard / screen-reader users can jump past
      the sticky header straight to the article body. Only visible on
      :focus, has a generous gold focus ring matching the brand.
    -->
    <a href="#main-content" class="skip-to-content">Перейти к содержимому</a>

    <slot />

    <!--
      Service-worker registration.
      • Skipped in dev (no real build hash → cache key is the literal
        "__BUILD_HASH__" placeholder, which would never invalidate).
      • Production: register on load, ignore failures (e.g. private mode).
    -->
    <script>
      if ('serviceWorker' in navigator) {
        var host = location.hostname
        var isDev = host === 'localhost' || host === '127.0.0.1' || host === '0.0.0.0'
        if (!isDev) {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').catch(() => {})
          })
        }
      }
    </script>
  </body>
</html>
